<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <ApplicationIcon>app.ico</ApplicationIcon>

    <Version>1.2.0</Version>
    <AssemblyVersion>1.2.0.0</AssemblyVersion>
    <FileVersion>1.2.0.0</FileVersion>
    <AssemblyName>SnapFlow</AssemblyName>
    <Authors>Onzi</Authors>
    <Company>Onzi</Company>
    <Product>SnapFlow</Product>
    <Copyright>Copyright © Onzi 2026</Copyright>
    <AssemblyTitle>SnapFlow</AssemblyTitle>
    <Description>SnapFlow — минималистичный скриншотер: захват области, копирование, сохранение, глобальные горячие клавиши.</Description>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="app.ico" />
  </ItemGroup>

</Project>
