<Window x:Class="Screenshoter.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False" Topmost="True"
        Cursor="Cross" SnapsToDevicePixels="True" UseLayoutRounding="True">

    <Window.Resources>
        <!-- Компактная иконочная кнопка панели -->
        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="5" Background="#00FFFFFF">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Bg"
                                                Storyboard.TargetProperty="Background.Color"
                                                To="#1AFFFFFF" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Bg"
                                                Storyboard.TargetProperty="Background.Color"
                                                To="#00FFFFFF" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Маркер ресайза 8x8 -->
        <Style x:Key="ResizeThumb" TargetType="Thumb">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Rectangle Fill="White" Stroke="Black" StrokeThickness="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <!-- Живой скриншот экрана -->
        <Image x:Name="BackgroundImage" Stretch="Fill"/>

        <!-- Затемнение с "вырезом" (EvenOdd) -->
        <Path x:Name="DimPath" Fill="Black" Opacity="0.4" IsHitTestVisible="False">
            <Path.Data>
                <GeometryGroup FillRule="EvenOdd">
                    <RectangleGeometry x:Name="FullRectGeo"/>
                    <RectangleGeometry x:Name="SelectionGeo"/>
                </GeometryGroup>
            </Path.Data>
        </Path>

        <!-- Тонкая рамка выделения -->
        <Rectangle x:Name="SelectionBorder" Stroke="#0A84FF" StrokeThickness="1"
                   HorizontalAlignment="Left" VerticalAlignment="Top"
                   Visibility="Collapsed" IsHitTestVisible="False"/>

        <!-- Слой интерактива: маркеры + панель -->
        <Canvas x:Name="OverlayCanvas">
            <!-- 8 маркеров ресайза -->
            <Thumb x:Name="ThumbTL" Style="{StaticResource ResizeThumb}" Cursor="SizeNWSE" Visibility="Collapsed"/>
            <Thumb x:Name="ThumbT"  Style="{StaticResource ResizeThumb}" Cursor="SizeNS"   Visibility="Collapsed"/>
            <Thumb x:Name="ThumbTR" Style="{StaticResource ResizeThumb}" Cursor="SizeNESW" Visibility="Collapsed"/>
            <Thumb x:Name="ThumbR"  Style="{StaticResource ResizeThumb}" Cursor="SizeWE"   Visibility="Collapsed"/>
            <Thumb x:Name="ThumbBR" Style="{StaticResource ResizeThumb}" Cursor="SizeNWSE" Visibility="Collapsed"/>
            <Thumb x:Name="ThumbB"  Style="{StaticResource ResizeThumb}" Cursor="SizeNS"   Visibility="Collapsed"/>
            <Thumb x:Name="ThumbBL" Style="{StaticResource ResizeThumb}" Cursor="SizeNESW" Visibility="Collapsed"/>
            <Thumb x:Name="ThumbL"  Style="{StaticResource ResizeThumb}" Cursor="SizeWE"   Visibility="Collapsed"/>

            <!-- Премиальная панель инструментов -->
            <Border x:Name="Toolbar" Height="32" CornerRadius="6" Padding="4,0"
                    Background="#1C1C1E" Opacity="0" Visibility="Collapsed"
                    VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.4" Color="Black"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnCopy" Style="{StaticResource ToolButton}" ToolTip="Копировать">
                        <Path Fill="White" Stretch="Uniform" Width="14" Height="14"
                              Data="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"/>
                    </Button>
                    <Button x:Name="BtnSave" Style="{StaticResource ToolButton}" ToolTip="Сохранить">
                        <Path Fill="White" Stretch="Uniform" Width="14" Height="14"
                              Data="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h12c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z"/>
                    </Button>
                    <Button x:Name="BtnClose" Style="{StaticResource ToolButton}" ToolTip="Закрыть">
                        <Path Fill="White" Stretch="Uniform" Width="14" Height="14"
                              Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
                    </Button>
                </StackPanel>
            </Border>
        </Canvas>
    </Grid>
</Window>
