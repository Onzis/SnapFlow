<Window x:Class="Screenshoter.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки" Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True">

    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" CornerRadius="6" Background="#2C2C2E">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#3A3A3C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DialogButtonAccent" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" CornerRadius="6" Background="#0A84FF">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#3395FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="10" Background="#1C1C1E" Padding="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.5" Color="Black"/>
        </Border.Effect>
        <StackPanel>
            <TextBlock Text="Горячая клавиша скриншота" Foreground="White"
                       FontSize="15" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Text="Нажмите нужную комбинацию клавиш" Foreground="#8E8E93"
                       FontSize="12" Margin="0,0,0,14"/>

            <Border x:Name="RecorderBox" CornerRadius="6" Background="#2C2C2E"
                    BorderBrush="#3A3A3C" BorderThickness="1" Height="44"
                    Focusable="True">
                <TextBlock x:Name="HotkeyText" Text="Shift + Alt + S" Foreground="White"
                           FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="HintText" Text="" Foreground="#FF453A"
                       FontSize="11" Margin="2,6,0,0" MinHeight="14"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button x:Name="BtnCancel" Content="Отмена" Width="90" Height="32"
                        Margin="0,0,10,0" Style="{StaticResource DialogButton}"/>
                <Button x:Name="BtnSave" Content="Сохранить" Width="110" Height="32"
                        Style="{StaticResource DialogButtonAccent}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
